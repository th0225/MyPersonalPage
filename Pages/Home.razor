@page "/"
@using MyPersonalPage.Components

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4 pb-16">
    @* --- 第一區：首頁 (Hero) --- *@
    <HeroSection />

    @* --- 第二區：生活 (Lifestyle) --- *@
    <LifeStyleSection />

    @* --- 第三區：技術棧 (Skills) --- *@
    <SkillSection />

    @* --- 第四區：專案 (Projects) --- *@
    <ProjectSection />

    @* --- 第五區：社群連結 (Social Connect) --- *@
    <ConnectSection />

    @* 底部留白，確保捲動空間 *@
    <div style="height: 100px;"></div>

</MudContainer>

<style>
    /* 1. 解決白邊：確保底層背景色統一，並禁止橫向捲動 */
    html, body {
        background-color: #FFFDF9 !important;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        width: 100%;
    }

    /* 2. 修正 MudContainer：只在手機版 (小於 600px) 強制 100% */
    @@media (max-width: 600px) {
        .mud-container {
            max-width: 100% !important; /* 手機版撐滿，防止白邊 */
            padding-left: 16px !important;
            padding-right: 16px !important;
        }
    }

    /* 3. 在電腦版 (大於 600px)，我們不寫 !important，
       讓 MudContainer MaxWidth="MaxWidth.Small" 自己發揮作用 */
    @@media (min-width: 601px) {
        .mud-container {
            /* 這裡不需要寫寬度，MudBlazor 會自動根據 Small 設定為約 960px */
            margin-left: auto;
            margin-right: auto;
        }
    }

    /* 4. 修正內容物：確保所有 Section 內容都不會超出螢幕 */
    .section-container, .cycling-card, img {
        max-width: 100%;
        box-sizing: border-box; /* 確保 Padding 不會增加寬度 */
    }
</style>