@page "/"
@using MyPersonalPage.Components

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4 pb-16">
    @* --- 第一區：首頁 (Hero) --- *@
    <HeroSection />

    @* --- 第二區：生活 (Lifestyle) --- *@
    <LifeStyleSection />

    @* --- 第三區：技術棧 (Skills) --- *@
    <SkillSection />

    @* --- 第四區：專案 (Projects) --- *@
    <ProjectSection />

    @* --- 第五區：社群連結 (Social Connect) --- *@
    <ConnectSection />

    @* 底部留白，確保捲動空間 *@
    <div style="height: 100px;"></div>

</MudContainer>

<style>
    /* 讓捲動位置更準確，預留給 AppBar 的空間 */
    div[id] {
        scroll-margin-top: 70px;
    }

    /* 讓區塊更有質感的微調 */
    .section-container {
        border-radius: 24px;
        transition: all 0.3s ease;
    }
</style>