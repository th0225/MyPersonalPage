@inject HttpClient Http

<div id="lifestyle" class="py-12 section-container"
    style="background-color: #FAF9F6; margin: 0 -16px; padding: 32px;">
    @* 標題區 *@
    <div class="d-flex align-center mb-8">
        <MudText Typo="Typo.h5" Style="font-weight: 800; color: #A68966;
            letter-spacing: 1px;">
            Lifestyle
        </MudText>
        <MudDivider Class="ml-4 flex-grow-1"
            Style="border-color: #EBE3D5; border-width: 2px;" />
    </div>

    <MudGrid Spacing="4">
        @* --- 單車數據看板 --- *@
        <MudItem xs="12" md="12">
            <MudPaper Elevation="0" Class="pa-6"
                Style="background: #FFF9F3; border-radius: 24px;
                    border: 1px solid #EBE3D5;">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Rounded.DirectionsBike"
                        Style="color: #A68966;" Class="mr-2" />
                    <MudText Typo="Typo.h6" Style="color: #5C4B3A;
                        font-weight: 800;">
                        最新騎乘訓練
                    </MudText>
                    <MudSpacer />
                    @if (_latestActivity != null)
                    {
                        <MudChip T="string" Size="Size.Small"
                            Variant="Variant.Text" Style="color: #A68966;
                                background: #EBE3D5;">
                            @_latestActivity.Name
                        </MudChip>
                    }
                </div>

                @if (_latestActivity == null)
                {
                    <MudProgressLinear Color="Color.Default"
                        Indeterminate="true" Class="my-7" />
                }
                else
                {
                    <MudGrid Spacing="2">
                        <MudItem xs="6" sm="3">
                            <div class="stat-card">
                                <MudText Typo="Typo.caption"
                                    Style="color: #7A6F62;">
                                    距離
                                </MudText>
                                <MudText Typo="Typo.h5"
                                    Style="font-weight: 900; color: #5C4B3A;">
                                    @_latestActivity.Distance
                                    <span style="font-size: 14px;
                                        margin-left: 2px;">
                                        km
                                    </span>
                                </MudText>
                            </div>
                        </MudItem>

                        <MudItem xs="6" sm="3">
                            <div class="stat-card">
                                <MudText Typo="Typo.caption"
                                    Style="color: #7A6F62;">
                                    爬升
                                </MudText>
                                <MudText Typo="Typo.h5"
                                    Style="font-weight: 900; color: #5C4B3A;">
                                    @_latestActivity.Elevation
                                    <span style="font-size: 14px;
                                        margin-left: 2px;">
                                        m
                                    </span>
                                </MudText>
                            </div>
                        </MudItem>

                        <MudItem xs="6" sm="3">
                            <div class="stat-card">
                                <MudText Typo="Typo.caption"
                                    Style="color: #7A6F62;">
                                    平均功率
                                </MudText>
                                <MudText Typo="Typo.h5"
                                    Style="font-weight: 900; color: #5C4B3A;">
                                    @_latestActivity.AverageWatts
                                    <span style="font-size: 14px;
                                        margin-left: 2px;">
                                        W
                                    </span>
                                </MudText>
                            </div>
                        </MudItem>

                        <MudItem xs="6" sm="3">
                            <div class="stat-card">
                                <MudText Typo="Typo.caption"
                                    Style="color: #7A6F62;">
                                    耗時
                                </MudText>
                                <MudText Typo="Typo.h6"
                                    Style="font-weight: 900; color: #5C4B3A;
                                        margin-top: 4px;">
                                    @_latestActivity.DisplayTime
                                </MudText>
                            </div>
                        </MudItem>
                    </MudGrid>

                    <div class="d-flex align-center mt-4 pt-4"
                        style="border-top: 1px dashed #EBE3D5;">
                        <MudIcon Icon="@Icons.Material.Rounded.Bolt"
                            Size="Size.Small" Style="color: #FACC15;" />
                        <MudText Typo="Typo.caption" Class="ml-1"
                            Style="color: #7A6F62;">
                            最高功率: @_latestActivity.MaxWatts W | FTP: 215W
                        </MudText>
                        <MudSpacer />
                        <MudLink 
                            href="https://www.strava.com/athletes/25929657"
                            Target="_blank" Underline="Underline.None">
                            <MudText Typo="Typo.caption"
                                Style="color: #A68966; font-weight: 700;">
                                VIEW ON STRAVA
                            </MudText>
                        </MudLink>
                    </div>
                }
            </MudPaper>
        </MudItem>

        @* --- 咖啡看板 --- *@
        <MudItem xs="12" md="12">
            <MudPaper Elevation="0" Class="pa-5"
                Style="background: #F5F2ED; border-radius: 20px;">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.LocalCafe"
                        Class="mr-3" Style="color: #A68966;" />
                    <div>
                        <MudText Typo="Typo.body1"
                            Style="font-weight: 700; color: #5C4B3A;">
                                今日咖啡配方
                        </MudText>
                        <MudText Typo="Typo.body2"
                            Style="color: #7A6F62;">
                            衣索比亞 古吉 鳥拉嘎 日曬 / 93°C / 手沖
                        </MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        @* --- 主子戶動看板 --- *@
        <MudItem xs="12" md="12">
            @* --- 貓咪互動卡片 --- *@
            <MudPaper Elevation="0" Class="pa-5 relative overflow-hidden" 
                    Style="background: #EBE3D5; border-radius: 20px;
                    cursor: pointer;" @onclick="InteractWithCat">
                <div class="d-flex align-center">
                    <MudAvatar Style="background-color: #FFFFFF;"
                        Class="mr-3">
                        <MudIcon Icon="@_currentCatIcon"
                            Size="Size.Small"
                            Style="color: #A68966;" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.body1"
                            Style="font-weight: 700; color: #5C4B3A;">
                                My Boss
                        </MudText>
                        <MudText Typo="Typo.caption"
                            Style="color: #7A6F62;">
                            @_catStatus
                        </MudText>
                    </div>
                </div>
                
                @* 加入一個隱形的小彩蛋提示 *@
                <MudText Typo="Typo.caption"
                    Style="position:absolute; bottom:4px; right:12px;
                        opacity:0.3; font-size: 10px;">
                    (點擊主子進行互動)
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

<style>
    .stat-item {
        padding: 12px;
        background: #FAF9F6;
        border-radius: 16px;
        text-align: center;
    }
    .stat-unit {
        font-size: 14px;
        color: #A68966;
        margin-left: 3px;
    }
</style>

@code {
    private StravaActivity _latestActivity = new();
    private bool _isLoading = true;
    private string _catStatus = "正在沙發上進行監督作業";
    private string _currentCatIcon = Icons.Material.Filled.Pets;
    private int _interactionCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        try
        {
            _latestActivity = await Http.GetFromJsonAsync<StravaActivity>(
                "data/strava.json"
            );
        }
        catch (Exception ex)
        {
            Console.WriteLine($"資料讀取失敗: {ex.Message}");
        }
    }

    private void InteractWithCat()
    {
        _interactionCount++;

        switch (_interactionCount % 6)
        {
            case 1:
                _catStatus = "頭靠了過來，準備讓你摸摸";
                _currentCatIcon = Icons.Material.Filled.Favorite;
                break;
            case 2:
                _catStatus = "下巴抬了起來，讓你換個地方摸摸";
                _currentCatIcon = Icons.Material.Filled.Favorite;
                break;
            case 3:
                _catStatus = "感受到你的摸摸，發出了呼嚕聲";
                _currentCatIcon = Icons.Material.Filled.Favorite;
                break;
            case 4:
                _catStatus = "摸太久了，決定把你當成潔牙骨玩";
                _currentCatIcon = Icons.Material.Filled.RemoveRedEye;
                break;
            case 5:
                _catStatus = "玩累了，決定去吃乾乾";
                _currentCatIcon = Icons.Material.Filled.Restaurant;
                break;
            default:
                _catStatus = "吃飽了，準備開始長達 16 小時的午睡";
                _currentCatIcon = Icons.Material.Filled.Bedtime;
                break;
        }
    }
}